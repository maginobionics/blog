---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="About ｜ Ocean Field"
  description="Who runs this little blog."
  path="about"
>
  <section class="card" aria-labelledby="about-h">
    <h2 class="sec-head" id="about-h">About <span class="en">HELLO</span></h2>
    <p>
      Hi — this is my small corner of the web. I post short notes and the
      occasional picture here. Nothing fancy, just things I want to keep.
    </p>
    <dl class="profile">
      <div><dt>Name</dt><dd>Your name here</dd></div>
      <div><dt>Doing</dt><dd>Building things, taking walks</dd></div>
      <div><dt>Here</dt><dd>Short posts &amp; pictures</dd></div>
      <div><dt>Since</dt><dd>2026</dd></div>
    </dl>
  </section>
</BaseLayout>
