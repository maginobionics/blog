---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import BaseLayout from "../layouts/BaseLayout.astro";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

const BASE = import.meta.env.BASE_URL.replace(/\/$/, "");
const postUrl = (id: string) => `${BASE}/posts/${id}/`;
const fmt = (d: Date) =>
  d.toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" });
---

<BaseLayout
  title="Ocean Field"
  description="A little hand-made blog: short posts and pictures."
  path="home"
>
  <section class="card" aria-labelledby="blog-h">
    <h2 class="sec-head" id="blog-h">Blog <span class="en">LATEST</span></h2>

    {
      posts.map((post) => (
        <article class="entry">
          <h3 class="date-head">
            <a href={postUrl(post.id)}>{post.data.title}</a>
          </h3>
          <p class="mood">{fmt(post.data.date)}</p>
          {post.data.image && (
            <a href={postUrl(post.id)}>
              <Image
                class="thumb"
                src={post.data.image}
                alt={post.data.imageAlt}
                loading="lazy"
              />
            </a>
          )}
          {post.data.description && <p>{post.data.description}</p>}
          <p class="more">
            <a href={postUrl(post.id)}>read more ▶</a>
          </p>
        </article>
      ))
    }
  </section>
</BaseLayout>
